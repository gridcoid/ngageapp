stages:
  - build
  - deploy

build:dev:
  stage: build
  only:
    - dev
  image: docker:20.10.16-alpine3.16
  services:
    - name: docker:20.10.16-dind-alpine3.16
      alias: dind
  variables:
    DOCKER_HOST: tcp://dind:2375/
    DOCKER_DRIVER: overlay2
    DOCKER_TLS_CERTDIR: ""
  before_script:
    - docker login -u "$CI_REGISTRY_USER" -p "$CI_REGISTRY_PASSWORD" $CI_REGISTRY
  script:
    - cp .env-sample-dev .env
    - docker build --pull -t "$CI_REGISTRY_IMAGE:dev" .
    - docker push "$CI_REGISTRY_IMAGE:dev"
    - echo "Build successfully!"

build:
  stage: build
  only:
    - main
  image: docker:20.10.16-alpine3.16
  services:
    - name: docker:20.10.16-dind-alpine3.16
      alias: dind
  variables:
    DOCKER_HOST: tcp://dind:2375/
    DOCKER_DRIVER: overlay2
    DOCKER_TLS_CERTDIR: ""
  before_script:
    - docker login -u "$CI_REGISTRY_USER" -p "$CI_REGISTRY_PASSWORD" $CI_REGISTRY
  script:
    - cp .env-sample .env
    - docker build --pull -t "$CI_REGISTRY_IMAGE" .
    - docker push "$CI_REGISTRY_IMAGE"
    - echo "Build successfully!"

deploy:dev:
  stage: deploy
  only:
    - dev
    - ci-debug
  image: kroniak/ssh-client:3.15
  before_script:
    - echo "Deploy to server"
  script:
    - mkdir -p ~/.ssh
    - chmod 700 ~/.ssh
    - echo -e "Host *\n\tStrictHostKeyChecking no\n\n" > ~/.ssh/config
    - echo "$SSH_PRIVATE_KEY" > ~/.ssh/id_rsa
    - chmod 600 ~/.ssh/id_rsa
    - ssh $SSH_USER@$SSH_HOST docker pull registry.gitlab.com/unimind-kg/unimind-app:dev
    - ssh $SSH_USER@$SSH_HOST 'docker stop unimind-app-dev || true && docker rm unimind-app-dev || true'
    - ssh $SSH_USER@$SSH_HOST docker run -p 127.0.0.1:3001:3000 \
        -e BASE_URL=$API_BASE_URL \
        -d --name unimind-app-dev registry.gitlab.com/unimind-kg/unimind-app:dev

deploy:
  stage: deploy
  only:
    - main
  image: kroniak/ssh-client:3.15
  before_script:
    - echo "Deploy to server"
  script:
    - mkdir -p ~/.ssh
    - chmod 700 ~/.ssh
    - echo -e "Host *\n\tStrictHostKeyChecking no\n\n" > ~/.ssh/config
    - echo "$SSH_PRIVATE_KEY" > ~/.ssh/id_rsa
    - chmod 600 ~/.ssh/id_rsa
    - ssh $SSH_USER@$SSH_HOST docker pull registry.gitlab.com/unimind-kg/unimind-app
    - ssh $SSH_USER@$SSH_HOST 'docker stop unimind-app || true && docker rm unimind-app || true'
    - ssh $SSH_USER@$SSH_HOST docker run -p 127.0.0.1:3000:3000 \
        -e BASE_URL=$API_BASE_URL \
        -d --name unimind-app registry.gitlab.com/unimind-kg/unimind-app
